<Window x:Class="DigitalTwin.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DigitalTwin.Dashboard"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="Digital Twin - Pick and Place System" 
        Height="800" Width="1400"
        WindowState="Maximized"
        Background="#FF252526">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#FF2D2D30" BorderBrush="#FF007ACC" BorderThickness="0,0,0,2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 타이틀 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Digital Twin System" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="White"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Pick and Place Monitoring Dashboard" 
                              FontSize="14" 
                              Foreground="#FFAAAAAA"
                              VerticalAlignment="Bottom"
                              Margin="15,0,0,8"/>
                </StackPanel>

                <!-- 연결 상태 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FF3E3E42" Padding="15,8" CornerRadius="5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="PlcStatusIndicator" Width="12" Height="12" Fill="Red" Margin="0,0,8,0"/>
                            <TextBlock Text="PLC" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF3E3E42" Padding="15,8" CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="UnityStatusIndicator" Width="12" Height="12" Fill="Red" Margin="0,0,8,0"/>
                            <TextBlock Text="Unity" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 제어 패널 -->
            <Border Grid.Column="0" 
                    Background="#FF2D2D30" 
                    Padding="15"
                    BorderBrush="#FF3E3E42" 
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="제어 패널" 
                                  FontSize="22" 
                                  FontWeight="Bold" 
                                  Foreground="White" 
                                  Margin="0,0,0,20"/>

                        <!-- 제어 버튼 -->
                        <Button x:Name="BtnStart"
                               Content="▶ START"
                               Foreground="White"
                               Height="45"
                               FontSize="16"
                               FontWeight="Bold"
                               BorderThickness="0"
                               Cursor="Hand"
                               Margin="0,10,0,0"
                               Click="BtnStart_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF007ACC"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                       Background="{TemplateBinding Background}"
                                                       CornerRadius="5"
                                                       BorderThickness="2"
                                                       BorderBrush="Transparent"
                                                       RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FF0084D6"/>
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#FF00A8FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FF005A9E"/>
                                                        <Setter TargetName="border" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#FF3E3E42"/>
                                                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="BtnStop"
                               Content="■ STOP"
                               Foreground="White"
                               Height="45"
                               FontSize="16"
                               FontWeight="Bold"
                               BorderThickness="0"
                               Cursor="Hand"
                               Margin="0,8"
                               Click="BtnStop_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFD13438"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                       Background="{TemplateBinding Background}"
                                                       CornerRadius="5"
                                                       BorderThickness="2"
                                                       BorderBrush="Transparent"
                                                       RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FFE14044"/>
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#FFFF6B6B"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FFB02A2E"/>
                                                        <Setter TargetName="border" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#FF3E3E42"/>
                                                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="BtnReset"
                               Content="🔔 알람 클리어"
                               Foreground="White"
                               Height="40"
                               FontSize="14"
                               FontWeight="SemiBold"
                               BorderThickness="0"
                               Cursor="Hand"
                               Margin="0,0,0,8"
                               Click="BtnReset_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF3E3E42"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                       Background="{TemplateBinding Background}"
                                                       CornerRadius="5"
                                                       BorderThickness="2"
                                                       BorderBrush="Transparent"
                                                       RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FF4E4E52"/>
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#FF6E6E72"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FF2E2E32"/>
                                                        <Setter TargetName="border" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="BtnHome"
                               Content="⌂ 원점 복귀" 
                               Background="#FF3E3E42" 
                               Foreground="White" 
                               Height="40" 
                               FontSize="14"
                               FontWeight="SemiBold"
                               BorderThickness="0"
                               Cursor="Hand"
                               Click="BtnHome_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                       CornerRadius="5"
                                                       BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF4E4E52"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 수동 제어 -->
                        <GroupBox Header="수동 제어 (테스트)"
                                 Foreground="White"
                                 BorderBrush="#FF3E3E42"
                                 Margin="0,20,0,0">
                            <StackPanel Margin="5">
                                <!-- 증분 단위 선택 -->
                                <TextBlock Text="증분 단위" Foreground="White" FontSize="12" Margin="0,5,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="RadioStep01" Content="0.1" Foreground="White"
                                                GroupName="StepSize" Grid.Column="0" FontSize="11"
                                                Checked="StepSize_Changed"/>
                                    <RadioButton x:Name="RadioStep05" Content="0.5" Foreground="White"
                                                GroupName="StepSize" Grid.Column="1" FontSize="11"
                                                Checked="StepSize_Changed"/>
                                    <RadioButton x:Name="RadioStep1" Content="1.0" Foreground="White"
                                                GroupName="StepSize" Grid.Column="2" IsChecked="True" FontSize="11"
                                                Checked="StepSize_Changed"/>
                                    <RadioButton x:Name="RadioStepCustom" Content="커스텀" Foreground="White"
                                                GroupName="StepSize" Grid.Column="3" FontSize="11"
                                                Checked="StepSize_Changed"/>
                                </Grid>
                                <TextBox x:Name="TxtCustomStep"
                                        Text="5.0"
                                        Background="#FF3E3E42"
                                        Foreground="White"
                                        BorderBrush="#FF5E5E62"
                                        Height="25"
                                        Margin="0,5,0,10"
                                        Padding="5,3"
                                        FontSize="12"
                                        HorizontalContentAlignment="Center"
                                        IsEnabled="False"/>

                                <!-- X축 -->
                                <TextBlock Text="X축 (mm)" Foreground="White" FontSize="12" Margin="0,5,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnXMinus" Content="−" Grid.Column="0"
                                           Background="#FF3E3E42" Foreground="White"
                                           FontSize="18" FontWeight="Bold" Height="35"
                                           BorderThickness="0" Cursor="Hand"
                                           Click="BtnXMinus_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF5E5E62"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock x:Name="TxtXValue" Grid.Column="1"
                                              Text="0.0"
                                              Foreground="#FF00D9FF"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <Button x:Name="BtnXPlus" Content="+" Grid.Column="2"
                                           Background="#FF3E3E42" Foreground="White"
                                           FontSize="18" FontWeight="Bold" Height="35"
                                           BorderThickness="0" Cursor="Hand"
                                           Click="BtnXPlus_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF5E5E62"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <!-- Y축 -->
                                <TextBlock Text="Y축 (mm)" Foreground="White" FontSize="12" Margin="0,12,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnYMinus" Content="−" Grid.Column="0"
                                           Background="#FF3E3E42" Foreground="White"
                                           FontSize="18" FontWeight="Bold" Height="35"
                                           BorderThickness="0" Cursor="Hand"
                                           Click="BtnYMinus_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF5E5E62"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock x:Name="TxtYValue" Grid.Column="1"
                                              Text="0.0"
                                              Foreground="#FF00FF90"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <Button x:Name="BtnYPlus" Content="+" Grid.Column="2"
                                           Background="#FF3E3E42" Foreground="White"
                                           FontSize="18" FontWeight="Bold" Height="35"
                                           BorderThickness="0" Cursor="Hand"
                                           Click="BtnYPlus_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF5E5E62"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <!-- Z축 -->
                                <TextBlock Text="Z축 (mm)" Foreground="White" FontSize="12" Margin="0,12,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnZMinus" Content="−" Grid.Column="0"
                                           Background="#FF3E3E42" Foreground="White"
                                           FontSize="18" FontWeight="Bold" Height="35"
                                           BorderThickness="0" Cursor="Hand"
                                           Click="BtnZMinus_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF5E5E62"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock x:Name="TxtZValue" Grid.Column="1"
                                              Text="0.0"
                                              Foreground="#FFFF9900"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <Button x:Name="BtnZPlus" Content="+" Grid.Column="2"
                                           Background="#FF3E3E42" Foreground="White"
                                           FontSize="18" FontWeight="Bold" Height="35"
                                           BorderThickness="0" Cursor="Hand"
                                           Click="BtnZPlus_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF5E5E62"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 중앙: 데이터 표시 -->
            <Grid Grid.Column="1" Background="#FF1E1E1E" Margin="10">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" 
                                               Background="#FF2D2D30" 
                                               BorderBrush="#FF3E3E42" 
                                               BorderThickness="1,1,1,0"
                                               CornerRadius="5,5,0,0"
                                               Padding="15,10"
                                               Margin="0,0,2,0">
                                            <ContentPresenter ContentSource="Header" 
                                                            HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#FF007ACC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="📊 실시간 모니터링" Height="40" VerticalAlignment="Top">
                        <Grid Background="#FF252526" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 차트 영역 -->
                            <lvc:CartesianChart x:Name="AxisChart"
                                               Grid.Row="0"
                                               ZoomMode="X">
                            </lvc:CartesianChart>

                            <!-- 범례 -->
                            <StackPanel Grid.Row="1"
                                       Orientation="Horizontal"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,5">
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Ellipse Width="12" Height="12" Fill="#FF00D9FF" Margin="0,0,5,0"/>
                                    <TextBlock Text="X축" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Ellipse Width="12" Height="12" Fill="#FF00FF90" Margin="0,0,5,0"/>
                                    <TextBlock Text="Y축" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Ellipse Width="12" Height="12" Fill="#FFFF9900" Margin="0,0,5,0"/>
                                    <TextBlock Text="Z축" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="⚠️ 알람 이력">
                        <Grid Background="#FF252526">
                            <DataGrid x:Name="AlarmDataGrid"
                                     AutoGenerateColumns="False"
                                     CanUserAddRows="False"
                                     CanUserDeleteRows="False"
                                     IsReadOnly="True"
                                     Background="#FF1E1E1E"
                                     Foreground="White"
                                     GridLinesVisibility="Horizontal"
                                     HorizontalGridLinesBrush="#FF3E3E42"
                                     BorderThickness="0"
                                     HeadersVisibility="Column"
                                     SelectionMode="Single"
                                     AlternatingRowBackground="#FF2D2D30"
                                     RowBackground="#FF252526"
                                     Margin="10"
                                     MouseDoubleClick="AlarmDataGrid_MouseDoubleClick">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FF2D2D30"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="10"/>
                                        <Setter Property="BorderBrush" Value="#FF3E3E42"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="No" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="시간" Binding="{Binding TimeRangeString}" Width="140"/>
                                    <DataGridTextColumn Header="레벨" Binding="{Binding LevelIcon}" Width="60"/>
                                    <DataGridTextColumn Header="위치" Binding="{Binding Location}" Width="100"/>
                                    <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="*"/>
                                    <DataGridTextColumn Header="횟수" Binding="{Binding CountString}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- 우측: 상태 정보 -->
            <Border Grid.Column="2" 
                    Background="#FF2D2D30" 
                    Padding="15"
                    BorderBrush="#FF3E3E42" 
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="시스템 상태" 
                                  FontSize="22" 
                                  FontWeight="Bold" 
                                  Foreground="White" 
                                  Margin="0,0,0,20"/>

                        <!-- 축 위치 -->
                        <GroupBox Header="축 위치 (mm)" 
                                 Foreground="White" 
                                 BorderBrush="#FF3E3E42"
                                 Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                          Text="X:" 
                                          Foreground="#FFAAAAAA" 
                                          FontSize="16"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCurrentX"
                                          Grid.Row="0" Grid.Column="1" 
                                          Text="0.0 mm" 
                                          Foreground="#FF00D9FF" 
                                          FontSize="18" 
                                          FontWeight="Bold"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                          Text="Y:" 
                                          Foreground="#FFAAAAAA" 
                                          FontSize="16"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCurrentY"
                                          Grid.Row="1" Grid.Column="1" 
                                          Text="0.0 mm" 
                                          Foreground="#FF00FF90" 
                                          FontSize="18" 
                                          FontWeight="Bold"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                          Text="Z:" 
                                          Foreground="#FFAAAAAA" 
                                          FontSize="16"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCurrentZ"
                                          Grid.Row="2" Grid.Column="1" 
                                          Text="0.0 mm" 
                                          Foreground="#FFFF9900" 
                                          FontSize="18" 
                                          FontWeight="Bold"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <!-- 축 속도 -->
                        <GroupBox Header="축 속도 (mm/s)" 
                                 Foreground="White" 
                                 BorderBrush="#FF3E3E42"
                                 Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                          Text="VX:" 
                                          Foreground="#FFAAAAAA" 
                                          FontSize="14"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtVelocityX"
                                          Grid.Row="0" Grid.Column="1" 
                                          Text="0.0" 
                                          Foreground="White" 
                                          FontSize="14"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                          Text="VY:" 
                                          Foreground="#FFAAAAAA" 
                                          FontSize="14"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtVelocityY"
                                          Grid.Row="1" Grid.Column="1" 
                                          Text="0.0" 
                                          Foreground="White" 
                                          FontSize="14"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                          Text="VZ:" 
                                          Foreground="#FFAAAAAA" 
                                          FontSize="14"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtVelocityZ"
                                          Grid.Row="2" Grid.Column="1" 
                                          Text="0.0" 
                                          Foreground="White" 
                                          FontSize="14"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <!-- 통계 -->
                        <GroupBox Header="금일 통계"
                                 Foreground="White"
                                 BorderBrush="#FF3E3E42"
                                 Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="사이클 횟수: "
                                              Foreground="#FFAAAAAA"
                                              FontSize="14"/>
                                    <TextBlock x:Name="TxtCycleCount"
                                              Text="0"
                                              Foreground="White"
                                              FontSize="14"
                                              FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="평균 시간: "
                                              Foreground="#FFAAAAAA"
                                              FontSize="14"/>
                                    <TextBlock x:Name="TxtAvgTime"
                                              Text="0.0s"
                                              Foreground="White"
                                              FontSize="14"
                                              FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="알람: "
                                              Foreground="#FFAAAAAA"
                                              FontSize="14"/>
                                    <TextBlock x:Name="TxtAlarmCount"
                                              Text="0건"
                                              Foreground="#FFFFCC00"
                                              FontSize="14"
                                              FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- 알람 설정 -->
                        <GroupBox Header="⚙️ 알람 설정"
                                 Foreground="White"
                                 BorderBrush="#FF3E3E42">
                            <StackPanel Margin="10">
                                <TextBlock Text="체크 간격 (초)"
                                          Foreground="#FFAAAAAA"
                                          FontSize="12"
                                          Margin="0,0,0,5"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <Slider x:Name="SliderCheckInterval"
                                           Grid.Column="0"
                                           Minimum="1"
                                           Maximum="60"
                                           Value="30"
                                           TickFrequency="1"
                                           IsSnapToTickEnabled="True"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           ValueChanged="SliderCheckInterval_ValueChanged"/>

                                    <TextBlock x:Name="TxtCheckInterval"
                                              Grid.Column="1"
                                              Text="30s"
                                              Foreground="#FF00D9FF"
                                              FontSize="14"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="1초 = 즉시, 30초 = 표준, 60초 = 느림"
                                          Foreground="#FF666666"
                                          FontSize="10"
                                          Margin="0,5,0,0"
                                          TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="#FF007ACC" BorderBrush="#FF005A9E" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtStatusMessage"
                          Grid.Column="0"
                          Text="준비" 
                          Foreground="White" 
                          FontSize="12"
                          VerticalAlignment="Center"/>

                <TextBlock x:Name="TxtDateTime"
                          Grid.Column="1"
                          Text="2025-02-13 14:30:00" 
                          Foreground="White" 
                          FontSize="12"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
